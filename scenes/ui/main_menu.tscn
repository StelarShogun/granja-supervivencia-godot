[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/main_menu.gd" id="1_menu_script"]
[ext_resource type="StyleBox" path="res://assets/ui/panel_bg.tres" id="2_panel_bg"]

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_menu_script")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.06, 0.11, 0.08, 1)

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -230.0
offset_top = -190.0
offset_right = 230.0
offset_bottom = 190.0
theme_override_styles/panel = ExtResource("2_panel_bg")

[node name="MenuButtons" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 12
alignment = 1

[node name="Title" type="Label" parent="Panel/MenuButtons"]
layout_mode = 2
theme_override_font_sizes/font_size = 34
text = "Finca: Rescate y Supervivencia"
horizontal_alignment = 1
autowrap_mode = 3

[node name="ContinueButton" type="Button" parent="Panel/MenuButtons"]
custom_minimum_size = Vector2(320, 42)
layout_mode = 2
text = "Continuar juego"

[node name="NewGameButton" type="Button" parent="Panel/MenuButtons"]
custom_minimum_size = Vector2(320, 42)
layout_mode = 2
text = "Nueva partida"

[node name="SettingsButton" type="Button" parent="Panel/MenuButtons"]
custom_minimum_size = Vector2(320, 42)
layout_mode = 2
text = "Ajustes"

[node name="QuitButton" type="Button" parent="Panel/MenuButtons"]
custom_minimum_size = Vector2(320, 42)
layout_mode = 2
text = "Salir"

[node name="MessageLabel" type="Label" parent="Panel"]
layout_mode = 2
theme_override_font_sizes/font_size = 16
text = ""
horizontal_alignment = 1
