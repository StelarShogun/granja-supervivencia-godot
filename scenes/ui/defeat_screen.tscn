[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/defeat_screen.gd" id="1_defeat_script"]
[ext_resource type="StyleBox" path="res://assets/ui/panel_bg.tres" id="2_panel_bg"]

[node name="DefeatScreen" type="CanvasLayer"]
process_mode = 3
script = ExtResource("1_defeat_script")

[node name="Panel" type="PanelContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = ExtResource("2_panel_bg")

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 12
alignment = 1

[node name="LabelTitle" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 36
text = "Derrota"
horizontal_alignment = 1

[node name="LabelSub" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Te quedaste sin vida."
horizontal_alignment = 1
autowrap_mode = 3

[node name="BtnRestart" type="Button" parent="Panel/VBox"]
custom_minimum_size = Vector2(220, 40)
layout_mode = 2
text = "Reintentar"

[node name="BtnQuit" type="Button" parent="Panel/VBox"]
custom_minimum_size = Vector2(220, 40)
layout_mode = 2
text = "Menú principal"
