; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Granja Supervivencia"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/icons/icon.svg"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[autoload]

SaveManager="*res://scripts/core/save_manager.gd"
DebugCam="*uid://dx8l2wspjg6oq"
AmbientCG="*uid://cnxneyd8ilml2"
_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/ambientcg/plugin.cfg", "res://addons/debug_camera/plugin.cfg", "res://addons/godot_ai/plugin.cfg", "res://addons/godot_doctor/plugin.cfg", "res://addons/godot_mcp_server/plugin.cfg", "res://addons/sky_3d/plugin.cfg", "res://addons/third-person-camera/plugin.cfg")

